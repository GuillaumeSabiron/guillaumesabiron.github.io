[loggers]
keys=root

[handlers]
keys=file,console

[formatters]
keys=simple,verbose

[logger_root]
level=INFO
handlers=file,console
qualname=

[handler_file]
class=FileHandler
level=INFO
formatter=verbose
args=('log.log', 'a')

[handler_console]
class=StreamHandler
level=INFO
formatter=simple
args=(sys.stdout,)

[formatter_simple]
format=%(levelname)s: %(message)s
datefmt=%H:%M:%S

[formatter_verbose]
format=%(asctime)s - %(name)s - %(levelname)s - %(message)s - Line: %(lineno)d
datefmt=%Y-%m-%d %H:%M:%S